{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore.SignalR": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Host=127.0.0.1;Port=5433;Database=quantflowbots;Username=qfb;Password=__SET_IN_APPSETTINGS_DEVELOPMENT__",
    "Redis": "127.0.0.1:6379"
  },
  "Security": {
    "EncryptionKey": "change-me-in-dotnet-user-secrets"
  },
  "Binance": {
    "RestBaseUrl": "https://api.binance.com",
    "WebSocketBaseUrl": "wss://stream.binance.com:9443",
